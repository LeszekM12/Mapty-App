{
  "compilerOptions": {
    "target":                "ES2020",
    "module":                "ESNext",
    "moduleResolution":      "Node",
    "outDir":                "./dist",
    "rootDir":               "./src",
    "strict":                true,
    "useDefineForClassFields": true,
    "esModuleInterop":       true,
    "allowSyntheticDefaultImports": true,
    "allowUmdGlobalAccess":  true,
    "types":                 ["leaflet"],
    "lib":                   ["ES2020", "DOM", "DOM.Iterable"],
    "sourceMap":             true,
    "skipLibCheck":          true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
